{
  "extends": "./jsconfig.typecheck.base.json",
  "compilerOptions": {
    "types": ["vitest/globals"]
  },
  "include": [
    "**/*.test.js",
    "**/*.contract.js",
    "**/*-test-helpers.js",
    "**/test-helpers/**/*.js",
    "**/test-fixtures.js",
    "**/*.d.ts"
  ],
  "exclude": ["node_modules", ".vite"]
}
